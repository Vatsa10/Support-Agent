# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Aiven PostgreSQL (with pgvector)
PG_URI=postgres://avnadmin:password@svc.aivencloud.com:25432/defaultdb?sslmode=verify-full
PG_SSLROOTCERT=./certs/aiven-ca.pem
RLS_ROLE=app_user

# Aiven Valkey
VALKEY_URI=rediss://default:password@svc.aivencloud.com:25432/0

# Admin API key (gate /admin/* endpoints)
ADMIN_API_KEY=change-me

# Master encryption key (Fernet; generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# App Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000

# Knowledge Base (per-tenant subdir: ./src/knowledge_base/<tenant_id>/)
KB_PATH=./src/knowledge_base/

# Search Settings
TOP_K_RETRIEVAL=5
CONFIDENCE_THRESHOLD=0.7
EMBEDDING_DIM=768

# Rate limit
RATE_LIMIT_PER_MIN=60
